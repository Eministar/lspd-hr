<?xml version="1.0" encoding="utf-8"?>
<!--
  IIS + iisnode für dieses Next.js-Projekt (Datei in den httpdocs neben package.json/start.js kopieren).

  Voraussetzungen auf dem Server:
  - IIS + URL Rewrite-Modul
  - iisnode-Modul (https://github.com/Azure/iisnode)
  - Node.js (Version wie in package.json "engines"; z. B. optional im iisnode-Handler festlegen)

  iisnode setzt beim Start automatisch Named-Pipe als process.env.PORT – start.js wertet das aus.
-->
<configuration>
  <system.webServer>
    <!-- Node-Einstiegsdatei (muss im selben Ordner wie diese web.config liegen) -->
    <handlers>
      <add
        name="iisnode"
        path="start.js"
        verb="*"
        modules="iisnode"
        resourceType="Unspecified"
        requireAccess="Script"
      />
    </handlers>

    <!-- Alle Requests an Next (Statik bedient Next intern aus /.next/, public/, …) -->
    <rewrite>
      <rules>
        <rule name="NextApp" stopProcessing="true">
          <match url=".*" />
          <action type="Rewrite" url="start.js" />
        </rule>
      </rules>
    </rewrite>

    <iisnode
      node_env="production"
      loggingEnabled="true"
      debuggingEnabled="false"
      devErrorsEnabled="false"
      maxConcurrentRequestsPerProcess="65536"
    />
  </system.webServer>
</configuration>
