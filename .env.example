# MySQL Datenbank
# Format: mysql://BENUTZER:PASSWORT@HOST:3306/DATENBANKNAME
DATABASE_URL="mysql://root:password@localhost:3306/lspd_hr"

# JWT Secret für Authentifizierung (unbedingt ändern!)
JWT_SECRET="dein-geheimer-schluessel-hier-aendern"

# Optional: Discord-Webhook für Start, Reload, Fehler und Live-Update-Status
DISCORD_WEBHOOK_URL=""

# Discord Bot Integration für HR-Meldungen, Rollen-Sync und Slash-Commands
DISCORD_BOT_TOKEN=""
DISCORD_PUBLIC_KEY=""
DISCORD_APPLICATION_ID=""
DISCORD_GUILD_ID=""
# Discord Developer Portal → General Information → Interactions Endpoint URL:
# https://deine-domain.tld/api/discord/interactions
DISCORD_ANNOUNCEMENTS_CHANNEL_ID=""
DISCORD_DUTY_STATUS_CHANNEL_ID=""
DISCORD_DUTY_ADMIN_LOG_CHANNEL_ID=""
DISCORD_ABSENCE_STATUS_CHANNEL_ID=""
DISCORD_BOT_GATEWAY_ENABLED="true"
DISCORD_BOT_STATUS="LSPD HR"
DISCORD_ROLE_SYNC_INTERVAL_MS="300000"

# Player-Online API für automatische Police-Spielzeit.
# Header: x-api-secret; Secret niemals clientseitig oder im Repo veröffentlichen.
PLAYER_ONLINE_API_URL="https://dash.nero-v.cc/api/external/player-online"
PLAYER_ONLINE_API_SECRET=""
PLAYER_ONLINE_POLICE_JOB="police"
PLAYER_ONLINE_SYNC_TTL_MS="15000"

# Optional: Token, falls ein externer Cron /api/status-automation ausführen soll.
STATUS_AUTOMATION_TOKEN=""

# Upload-API (POST /api/uploads). Header: x-api-key oder Authorization: Bearer <key>.
# Ohne gesetzten Key ist der Endpoint deaktiviert (503).
UPLOAD_API_KEY=""
UPLOAD_MAX_BYTES="10485760"

# Optional: GitHub-URL für den Link in der Seitenleiste
# NEXT_PUBLIC_GITHUB_URL="https://github.com/dein-user/dein-repo"
