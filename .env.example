# MySQL Datenbank
# Format: mysql://BENUTZER:PASSWORT@HOST:3306/DATENBANKNAME
DATABASE_URL="mysql://root:password@localhost:3306/lspd_hr"

# JWT Secret für Authentifizierung (unbedingt ändern!)
JWT_SECRET="dein-geheimer-schluessel-hier-aendern"

# Optional: Discord-Webhook für Start, Reload, Fehler und Live-Update-Status
DISCORD_WEBHOOK_URL=""

# Discord Bot Integration für HR-Meldungen, Rollen-Sync und Slash-Commands
DISCORD_BOT_TOKEN=""
DISCORD_PUBLIC_KEY=""
DISCORD_APPLICATION_ID=""
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""
DISCORD_GUILD_ID=""
# Discord Developer Portal → General Information → Interactions Endpoint URL:
# https://deine-domain.tld/api/discord/interactions
DISCORD_ANNOUNCEMENTS_CHANNEL_ID=""
DISCORD_SANCTIONS_CHANNEL_ID=""
DISCORD_DUTY_STATUS_CHANNEL_ID=""
DISCORD_DUTY_ADMIN_LOG_CHANNEL_ID=""
DISCORD_ABSENCE_STATUS_CHANNEL_ID=""
# Fallback-Channel für Arbeitsverträge: Wenn ein Officer keine DMs empfangen kann
# (DMs zu, kein gemeinsamer Server, keine Discord-ID), wird die Aufforderung zum
# Unterschreiben hier gepostet. Ohne Wert wird der Ankündigungs-Channel genutzt.
DISCORD_CONTRACTS_CHANNEL_ID=""
DISCORD_HUMAN_RESOURCES_ROLE_ID=""
DISCORD_BOT_GATEWAY_ENABLED="true"
# Für automatische Rollenvergabe beim Discord-Beitritt:
# Im Discord Developer Portal beim Bot den "Server Members Intent" aktivieren.
DISCORD_MEMBER_JOIN_SYNC_ENABLED="true"
DISCORD_ROLE_SYNC_ON_READY="true"
DISCORD_BOT_STATUS="LSPD HR"
DISCORD_ROLE_SYNC_INTERVAL_MS="300000"
# Kommagetrennte Discord-Rollen-IDs, die sich einloggen dürfen (Bootstrap-Fallback).
# Nur nötig wenn die DB-Einstellungen noch nicht über das Admin-Panel gesetzt wurden.
# Beispiel: DISCORD_AUTH_LOGIN_ROLE_IDS="123456789012345678,987654321098765432"
DISCORD_AUTH_LOGIN_ROLE_IDS=""

# Kommagetrennte Discord-Rollen-IDs, die das Bewerberportal öffnen dürfen.
# Diese Rollen geben keine Dashboard-Rechte.
# Beispiel: DISCORD_APPLICANT_ROLE_IDS="123456789012345678"
DISCORD_APPLICANT_ROLE_IDS=""

# Kommagetrennte Discord-Rollen-IDs, die automatisch VOLLE Admin-Rechte erhalten.
# Wird live aus den echten Discord-Rollen ausgewertet (unabhängig vom Gruppen-Mapping)
# und nie in der DB gespeichert, kann also vom Rollensync nicht entfernt werden.
# Wenn leer, wird DISCORD_AUTH_LOGIN_ROLE_IDS als Fallback verwendet (Alt-Verhalten).
# Beispiel: DISCORD_ADMIN_ROLE_IDS="123456789012345678"
DISCORD_ADMIN_ROLE_IDS=""

# Player-Online API für automatische Police-Spielzeit.
# Header: x-api-secret; Secret niemals clientseitig oder im Repo veröffentlichen.
PLAYER_ONLINE_API_URL="https://dash.nero-v.cc/api/external/player-online"
PLAYER_ONLINE_API_SECRET=""
PLAYER_ONLINE_POLICE_JOB="police"
PLAYER_ONLINE_SYNC_TTL_MS="15000"

# Optional: Token, falls ein externer Cron /api/status-automation ausführen soll.
STATUS_AUTOMATION_TOKEN=""

# Upload-API (POST /api/uploads). Header: x-api-key oder Authorization: Bearer <key>.
# Ohne gesetzten Key ist der Endpoint deaktiviert (503).
UPLOAD_API_KEY=""
UPLOAD_MAX_BYTES="10485760"
# Persistenter Upload-Ordner. Auf Plesk auf einen Ordner außerhalb des Deploy-/Build-Outputs setzen.
# Beispiel Windows/IIS: UPLOAD_DIR="C:\Inetpub\vhosts\deine-domain.tld\private\uploads"
# Beispiel Linux/Plesk: UPLOAD_DIR="/var/www/vhosts/deine-domain.tld/private/uploads"
# Ohne Wert nutzt die App ./uploads im Anwendungsstamm.
# UPLOAD_DIR=""

# Optional: GitHub-URL für den Link in der Seitenleiste
# NEXT_PUBLIC_GITHUB_URL="https://github.com/dein-user/dein-repo"

# Öffentliche Basis-URL der App — PFLICHT auf Produktionsserver!
# Wird für Discord OAuth2 redirect_uri verwendet. Ohne diesen Wert
# kann der Login-Callback auf localhost zurückfallen.
NEXT_PUBLIC_SITE_URL="https://deine-domain.tld"

# Hinweis zu CORS: Die Public API reflektiert standardmäßig JEDEN Origin.
# Da die Authentifizierung über Bearer-Tokens (lspd_…) läuft, ist der Origin
# kein Sicherheitskontext — wer ein gültiges Token hat, darf zugreifen.
# Bei Cookie-Auth greift der Same-Origin-Schutz des Browsers weiterhin.
