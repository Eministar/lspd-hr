generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum OfficerStatus {
  ACTIVE
  AWAY
  INACTIVE
  TERMINATED
}

enum UserRole {
  ADMIN
  HR
  LEADERSHIP
  READONLY
}

enum TaskModule {
  ACADEMY
  HR
  SRU
  DETECTIVE
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
}

enum TaskPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum OfficerFlag {
  RED
  ORANGE
  YELLOW
  BLUE
}

enum SanctionStatus {
  OPEN
  PAID
  ESCALATED
}

enum CalendarEventType {
  TRAINING
  MEETING
  ACADEMY
  EXAM
  HR_DEADLINE
  SRU_TRAINING
  SRU_OPERATION
  DETECTIVE_BRIEFING
  DETECTIVE_CASE
  OTHER
}

enum ProbationStatus {
  ACTIVE
  PASSED
  EXTENDED
  FAILED
}

model UserGroup {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?  @db.Text
  permissions Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  memberships UserGroupMembership[]
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String?
  displayName  String
  discordId    String?
  discordUsername String?
  discordGlobalName String?
  discordAvatar String?
  discordDiscriminator String?
  lastLoginAt  DateTime?
  role         UserRole @default(READONLY)
  groupId      String?
  group        UserGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  permissions  Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  groupMemberships UserGroupMembership[]
  promotionsPerformed PromotionLog[] @relation("PerformedBy")
  terminationsPerformed Termination[] @relation("TerminatedBy")
  sanctionsIssued      Sanction[]     @relation("SanctionIssuedBy")
  notesAuthored       Note[]         @relation("NoteAuthor")
  auditLogs           AuditLog[]     @relation("AuditUser")
  createdLists        RankChangeList[] @relation("ListCreator")
  rankChangeEntriesCreated RankChangeListEntry[] @relation("EntryCreator")
  taskListsCreated    TaskList[]     @relation("TaskListCreator")
  tasksCreated        Task[]         @relation("TaskCreator")
  calendarEventsCreated CalendarEvent[] @relation("CalendarEventCreator")
  sruFoldersCreated SruFolder[] @relation("SruFolderCreator")
  sruDocumentsCreated SruDocument[] @relation("SruDocumentCreator")
  sruDocumentsUpdated SruDocument[] @relation("SruDocumentUpdater")
  probationsCreated  Probation[]     @relation("ProbationCreator")
  probationsDecided  Probation[]     @relation("ProbationDecider")
  patrolBoardsCreated PatrolBoard[]  @relation("PatrolBoardCreator")
}

model UserGroupMembership {
  userId    String
  groupId   String
  source    String   @default("discord") // 'discord' | 'manual'
  createdAt DateTime @default(now())

  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  group UserGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([userId, groupId])
  @@index([groupId])
  @@index([userId, source])
}

model Unit {
  id        String   @id @default(cuid())
  key       String   @unique
  name      String
  color     String   @default("#d4af37")
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Rank {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int      @unique
  color     String   @default("#3B82F6")
  /// Inklusiver Zahlenbereich für Dienstnummern (nur Ziffern / Prefix+Ziffern). Null = kein autom. Bereich.
  badgeMin  Int?
  badgeMax  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  officers     Officer[]
  minimumForTrainings Training[] @relation("TrainingMinimumRank")
  oldRankLogs  PromotionLog[] @relation("OldRank")
  newRankLogs  PromotionLog[] @relation("NewRank")
  entryCurrentRanks  RankChangeListEntry[] @relation("EntryCurrentRank")
  entryProposedRanks RankChangeListEntry[] @relation("EntryProposedRank")
}

model Training {
  id        String   @id @default(cuid())
  key       String   @unique
  label     String
  sortOrder Int      @default(0)
  minRankId String?
  minRank   Rank?    @relation("TrainingMinimumRank", fields: [minRankId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  officerTrainings OfficerTraining[]

  @@index([minRankId])
}

model Officer {
  id              String        @id @default(cuid())
  badgeNumber     String        @unique
  /// Discord-Snowflake (nur Dashboard / Verknüpfung; ohne Bot-Anbindung)
  discordId       String?       @unique
  firstName       String
  lastName        String
  rankId          String
  rank            Rank          @relation(fields: [rankId], references: [id])
  status          OfficerStatus @default(ACTIVE)
  unit            String?
  units           Json?
  flag            OfficerFlag?
  notes           String?
  hireDate        DateTime      @default(now())
  lastOnline      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  trainings       OfficerTraining[]
  promotionLogs   PromotionLog[]
  terminations    Termination[]
  sanctions        Sanction[]
  officerNotes    Note[]         @relation("OfficerNotes")
  auditLogs       AuditLog[]     @relation("AuditOfficer")
  rankChangeEntries RankChangeListEntry[]
  taskAssignments TaskAssignment[] @relation("TaskAssigned")
  dutySessions    DutyTimeSession[]
  playtimeSessions PlaytimeSession[]
  absenceNotices  AbsenceNotice[]
  probation        Probation?
  calendarEvents   CalendarEvent[] @relation("CalendarEventOfficer")
  patrolAssignments PatrolAssignment[] @relation("PatrolAssigned")
}

model CalendarEvent {
  id                  String            @id @default(cuid())
  module              TaskModule?
  title               String
  description         String?           @db.Text
  type                CalendarEventType @default(OTHER)
  startsAt            DateTime
  endsAt              DateTime?
  location            String?
  officerId           String?
  officer             Officer?          @relation("CalendarEventOfficer", fields: [officerId], references: [id], onDelete: SetNull)
  createdById         String?
  createdBy           User?             @relation("CalendarEventCreator", fields: [createdById], references: [id], onDelete: SetNull)
  discordAnnouncement Boolean           @default(false)
  discordChannelId    String?
  discordMessageId    String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@index([startsAt])
  @@index([module, startsAt])
  @@index([type, startsAt])
  @@index([officerId, startsAt])
}

model SruFolder {
  id          String   @id @default(cuid())
  module      TaskModule @default(SRU)
  name        String
  description String?  @db.Text
  color       String   @default("#d4af37")
  sortOrder   Int      @default(0)
  createdById String?
  createdBy   User?    @relation("SruFolderCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  documents   SruDocument[]

  @@index([module, sortOrder, createdAt])
}

model SruDocument {
  id          String    @id @default(cuid())
  module      TaskModule @default(SRU)
  folderId    String?
  folder      SruFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  title       String
  content     String    @db.Text
  sortOrder   Int       @default(0)
  createdById String?
  createdBy   User?     @relation("SruDocumentCreator", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById String?
  updatedBy   User?     @relation("SruDocumentUpdater", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([folderId, sortOrder])
  @@index([module, updatedAt])
  @@index([updatedAt])
}

model Probation {
  id          String          @id @default(cuid())
  officerId   String          @unique
  officer     Officer         @relation(fields: [officerId], references: [id], onDelete: Cascade)
  startsAt    DateTime        @default(now())
  endsAt      DateTime
  status      ProbationStatus @default(ACTIVE)
  checklist   Json?
  resultNote  String?         @db.Text
  decidedAt   DateTime?
  decidedById String?
  decidedBy   User?           @relation("ProbationDecider", fields: [decidedById], references: [id], onDelete: SetNull)
  createdById String?
  createdBy   User?           @relation("ProbationCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([status, endsAt])
}

model AbsenceNotice {
  id              String   @id @default(cuid())
  officerId       String
  officer         Officer  @relation(fields: [officerId], references: [id], onDelete: Cascade)
  startsAt        DateTime @default(now())
  endsAt          DateTime
  reason          String   @db.Text
  source          String   @default("discord")
  actorDiscordId  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([officerId, startsAt])
  @@index([endsAt])
}

model DutyTimeSession {
  id             String    @id @default(cuid())
  officerId      String
  officer        Officer   @relation(fields: [officerId], references: [id], onDelete: Cascade)
  clockInAt      DateTime  @default(now())
  clockOutAt     DateTime?
  clockInSource  String    @default("dashboard")
  clockOutSource String?
  actorDiscordId String?
  activityCheckSentAt    DateTime?
  activityCheckMessageId String?
  activityCheckChannelId String?
  activityConfirmedAt    DateTime?
  autoClockedOut         Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([officerId, clockInAt])
  @@index([clockOutAt])
}

model PlaytimeSession {
  id             String    @id @default(cuid())
  officerId      String?
  officer        Officer?  @relation(fields: [officerId], references: [id], onDelete: SetNull)
  discordId      String?
  license        String?
  playerName     String
  sourceServerId Int?
  startedAt      DateTime  @default(now())
  endedAt        DateTime?
  lastSeenAt     DateTime  @default(now())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([officerId, startedAt])
  @@index([discordId])
  @@index([license])
  @@index([endedAt])
}

model OfficerTraining {
  id         String   @id @default(cuid())
  officerId  String
  officer    Officer  @relation(fields: [officerId], references: [id], onDelete: Cascade)
  trainingId String
  training   Training @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  completed  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([officerId, trainingId])
}

model PromotionLog {
  id                String   @id @default(cuid())
  officerId         String
  officer           Officer  @relation(fields: [officerId], references: [id], onDelete: Cascade)
  oldRankId         String
  oldRank           Rank     @relation("OldRank", fields: [oldRankId], references: [id])
  newRankId         String
  newRank           Rank     @relation("NewRank", fields: [newRankId], references: [id])
  oldBadgeNumber    String?
  newBadgeNumber    String?
  performedByUserId String?
  performedBy       User?    @relation("PerformedBy", fields: [performedByUserId], references: [id], onDelete: SetNull)
  note              String?
  createdAt         DateTime @default(now())
}

model Termination {
  id                  String    @id @default(cuid())
  /// Bei Löschen des Officers: null bleibt; Anzeige über previous*-Felder.
  officerId           String?
  officer             Officer?  @relation(fields: [officerId], references: [id], onDelete: SetNull)
  reason              String
  terminatedByUserId  String?
  terminatedBy        User?     @relation("TerminatedBy", fields: [terminatedByUserId], references: [id], onDelete: SetNull)
  terminatedAt        DateTime  @default(now())
  previousRank        String?
  previousBadgeNumber String?
  previousFirstName   String?
  previousLastName    String?
}

model Sanction {
  id                  String         @id @default(cuid())
  officerId           String?
  officer             Officer?       @relation(fields: [officerId], references: [id], onDelete: SetNull)
  reason              String         @db.Text
  penalGrade          String
  fineAmount          Int?
  penalty             String?        @db.Text
  status              SanctionStatus @default(OPEN)
  dueAt               DateTime?
  paidAt              DateTime?
  resolvedAt          DateTime?
  escalatedAt         DateTime?
  parentSanctionId    String?
  parentSanction      Sanction?      @relation("SanctionEscalation", fields: [parentSanctionId], references: [id], onDelete: SetNull)
  escalatedSanctions  Sanction[]     @relation("SanctionEscalation")
  discordChannelId    String?
  discordMessageId    String?
  issuedByUserId      String?
  issuedBy            User?          @relation("SanctionIssuedBy", fields: [issuedByUserId], references: [id], onDelete: SetNull)
  previousRank        String?
  previousBadgeNumber String?
  previousFirstName   String?
  previousLastName    String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([officerId, createdAt])
  @@index([issuedByUserId, createdAt])
  @@index([status, dueAt])
  @@index([parentSanctionId])
}

model Note {
  id        String   @id @default(cuid())
  officerId String?
  officer   Officer? @relation("OfficerNotes", fields: [officerId], references: [id], onDelete: Cascade)
  authorId  String?
  author    User?    @relation("NoteAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  title     String?
  content   String
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String
  officerId   String?
  officer     Officer? @relation("AuditOfficer", fields: [officerId], references: [id], onDelete: SetNull)
  userId      String?
  user        User?    @relation("AuditUser", fields: [userId], references: [id], onDelete: SetNull)
  oldValue    String?
  newValue    String?
  details     String?
  createdAt   DateTime @default(now())
}

model RankChangeList {
  id          String   @id @default(cuid())
  name        String
  description String?
  type        String   @default("PROMOTION") // PROMOTION or DEMOTION
  status      String   @default("DRAFT")     // DRAFT, COMPLETED
  createdById String?
  createdBy   User?    @relation("ListCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  entries RankChangeListEntry[]
}

model RankChangeListEntry {
  id             String   @id @default(cuid())
  listId         String
  list           RankChangeList @relation(fields: [listId], references: [id], onDelete: Cascade)
  officerId      String
  officer        Officer  @relation(fields: [officerId], references: [id], onDelete: Cascade)
  currentRankId  String
  currentRank    Rank     @relation("EntryCurrentRank", fields: [currentRankId], references: [id])
  proposedRankId String
  proposedRank   Rank     @relation("EntryProposedRank", fields: [proposedRankId], references: [id])
  newBadgeNumber String?
  note           String?
  executed       Boolean  @default(false)
  executedAt     DateTime?
  createdById    String?
  createdBy      User?    @relation("EntryCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt      DateTime @default(now())

  @@unique([listId, officerId])
}

model SystemSetting {
  id    String @id @default(cuid())
  key   String @unique
  /// JSON payloads (Discord role maps, etc.) exceed MySQL DEFAULT VARCHAR limits.
  value String @db.Text
}

model TaskList {
  id          String     @id @default(cuid())
  module      TaskModule
  title       String
  description String?    @db.Text
  color       String     @default("#d4af37")
  archived    Boolean    @default(false)
  sortOrder   Int        @default(0)
  createdById String?
  createdBy   User?      @relation("TaskListCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  tasks       Task[]

  @@index([module, archived])
}

model Task {
  id          String       @id @default(cuid())
  listId      String
  list        TaskList     @relation(fields: [listId], references: [id], onDelete: Cascade)
  title       String
  description String?      @db.Text
  status      TaskStatus   @default(OPEN)
  priority    TaskPriority @default(NORMAL)
  dueDate     DateTime?
  completedAt DateTime?
  sortOrder   Int          @default(0)
  createdById String?
  createdBy   User?        @relation("TaskCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  assignments TaskAssignment[]

  @@index([listId, status])
}

model TaskAssignment {
  id         String   @id @default(cuid())
  taskId     String
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  officerId  String
  officer    Officer  @relation("TaskAssigned", fields: [officerId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())

  @@unique([taskId, officerId])
  @@index([officerId])
}

model PatrolBoard {
  id          String   @id @default(cuid())
  title       String
  startsAt    DateTime
  createdById String?
  createdBy   User?    @relation("PatrolBoardCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  patrols     PatrolUnit[]

  @@index([startsAt])
}

model PatrolUnit {
  id         String   @id @default(cuid())
  boardId    String
  board      PatrolBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)
  name       String
  callSign   String?
  assignment String?  @db.Text
  notes      String?  @db.Text
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  members    PatrolAssignment[]

  @@index([boardId, sortOrder])
}

model PatrolAssignment {
  id         String   @id @default(cuid())
  patrolId   String
  patrol     PatrolUnit @relation(fields: [patrolId], references: [id], onDelete: Cascade)
  officerId  String
  officer    Officer @relation("PatrolAssigned", fields: [officerId], references: [id], onDelete: Cascade)
  sortOrder  Int      @default(0)
  assignedAt DateTime @default(now())

  @@unique([patrolId, officerId])
  @@index([officerId])
}

model BadgeBlacklist {
  id          String   @id @default(cuid())
  badgeNumber String   @unique
  reason      String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
