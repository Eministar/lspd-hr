generator client {
  // prisma-client-js emits a ready-to-require JavaScript client (client.js +
  // client.d.ts). The newer "prisma-client" generator emits TypeScript only,
  // which the production entry (start.js) cannot require without a TS loader.
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum OfficerStatus {
  ACTIVE
  AWAY
  INACTIVE
  TERMINATED
}

enum UserRole {
  ADMIN
  HR
  LEADERSHIP
  READONLY
}

enum TaskModule {
  ACADEMY
  HR
  SRU
  AIR_SUPPORT
  DETECTIVE
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
}

enum TaskPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum OfficerFlag {
  RED
  ORANGE
  YELLOW
  BLUE
}

enum SanctionStatus {
  OPEN
  PAID
  ESCALATED
}

enum CalendarEventType {
  TRAINING
  MEETING
  ACADEMY
  EXAM
  HR_DEADLINE
  SRU_TRAINING
  SRU_OPERATION
  AIR_SUPPORT_TRAINING
  AIR_SUPPORT_OPERATION
  OTHER
}

enum ProbationStatus {
  ACTIVE
  PASSED
  EXTENDED
  FAILED
}

enum AcademyResourceType {
  FILE
  LINK
}

enum AcademyResourceScope {
  GENERAL
  TRAINING
}

enum FormTestStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum FormTestKind {
  TEST
  SURVEY
}

enum FormQuestionType {
  SHORT_TEXT
  LONG_TEXT
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  SCALE
}

enum JobApplicationStatus {
  SUBMITTED
  IN_REVIEW
  HR_INTERVIEW
  ACCEPTED
  REJECTED
}

enum PressReleaseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model UserGroup {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?  @db.Text
  permissions Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  memberships UserGroupMembership[]
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String?
  displayName  String
  discordId    String?
  discordUsername String?
  discordGlobalName String?
  discordAvatar String?
  discordDiscriminator String?
  lastLoginAt  DateTime?
  role         UserRole @default(READONLY)
  groupId      String?
  group        UserGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  permissions  Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  groupMemberships UserGroupMembership[]
  promotionsPerformed PromotionLog[] @relation("PerformedBy")
  terminationsPerformed Termination[] @relation("TerminatedBy")
  sanctionsIssued      Sanction[]     @relation("SanctionIssuedBy")
  notesAuthored       Note[]         @relation("NoteAuthor")
  auditLogs           AuditLog[]     @relation("AuditUser")
  createdLists        RankChangeList[] @relation("ListCreator")
  rankChangeEntriesCreated RankChangeListEntry[] @relation("EntryCreator")
  taskListsCreated    TaskList[]     @relation("TaskListCreator")
  tasksCreated        Task[]         @relation("TaskCreator")
  calendarEventsCreated CalendarEvent[] @relation("CalendarEventCreator")
  sruFoldersCreated SruFolder[] @relation("SruFolderCreator")
  sruDocumentsCreated SruDocument[] @relation("SruDocumentCreator")
  sruDocumentsUpdated SruDocument[] @relation("SruDocumentUpdater")
  probationsCreated  Probation[]     @relation("ProbationCreator")
  probationsDecided  Probation[]     @relation("ProbationDecider")
  patrolBoardsCreated PatrolBoard[]  @relation("PatrolBoardCreator")
  apiTokensOwned      ApiToken[]     @relation("ApiTokenOwner")
  apiTokensCreated    ApiToken[]     @relation("ApiTokenCreator")
  academyResourcesCreated AcademyResource[] @relation("AcademyResourceCreator")
  formTestsCreated FormTest[] @relation("FormTestCreator")
  formResponsesSubmitted FormResponse[] @relation("FormResponseRespondent")
  formResponsesReviewed FormResponse[] @relation("FormResponseReviewer")
  formTestSessions FormTestSession[] @relation("FormTestSessionUser")
  jobApplicationsSubmitted JobApplication[] @relation("JobApplicationApplicant")
  jobApplicationsReviewed JobApplication[] @relation("JobApplicationReviewer")
  pressReleasesCreated PressRelease[] @relation("PressReleaseCreator")
  pressReleasesUpdated PressRelease[] @relation("PressReleaseUpdater")
}

model UserGroupMembership {
  userId    String
  groupId   String
  source    String   @default("discord") // 'discord' | 'manual'
  createdAt DateTime @default(now())

  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  group UserGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([userId, groupId])
  @@index([groupId])
  @@index([userId, source])
}

model Unit {
  id        String   @id @default(cuid())
  key       String   @unique
  name      String
  color     String   @default("#d4af37")
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Rank {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int
  color     String   @default("#3B82F6")
  /// Inklusiver Zahlenbereich für Dienstnummern (nur Ziffern / Prefix+Ziffern). Null = kein autom. Bereich.
  badgeMin  Int?
  badgeMax  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  officers     Officer[]
  minimumForTrainings Training[] @relation("TrainingMinimumRank")
  oldRankLogs  PromotionLog[] @relation("OldRank")
  newRankLogs  PromotionLog[] @relation("NewRank")
  entryCurrentRanks  RankChangeListEntry[] @relation("EntryCurrentRank")
  entryProposedRanks RankChangeListEntry[] @relation("EntryProposedRank")
}

model Training {
  id        String   @id @default(cuid())
  key       String   @unique
  label     String
  sortOrder Int      @default(0)
  minRankId String?
  minRank   Rank?    @relation("TrainingMinimumRank", fields: [minRankId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  officerTrainings OfficerTraining[]
  academyResources AcademyResource[]

  @@index([minRankId])
}

model AcademyResource {
  id                 String               @id @default(cuid())
  scope              AcademyResourceScope
  type               AcademyResourceType
  title              String
  description        String?              @db.Text
  trainingId         String?
  training           Training?            @relation(fields: [trainingId], references: [id], onDelete: SetNull)
  customTrainingName String?
  url                String?              @db.Text
  storedFilename     String?
  originalFilename   String?
  mimeType           String?
  size               Int?
  createdById        String?
  createdBy          User?                @relation("AcademyResourceCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  @@index([scope, createdAt])
  @@index([trainingId, createdAt])
  @@index([createdById])
}

model FormTest {
  id          String         @id @default(cuid())
  module      TaskModule
  kind        FormTestKind   @default(TEST)
  title       String
  description String?        @db.Text
  status      FormTestStatus @default(DRAFT)
  timeLimitMinutes Int?
  anonymousResponses Boolean @default(false)
  shareToken  String         @unique
  createdById String?
  createdBy   User?          @relation("FormTestCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  questions   FormQuestion[]
  responses   FormResponse[]
  sessions    FormTestSession[]

  @@index([module, status, updatedAt])
  @@index([createdById])
}

model FormQuestion {
  id          String           @id @default(cuid())
  testId      String
  test        FormTest         @relation(fields: [testId], references: [id], onDelete: Cascade)
  type        FormQuestionType
  title       String           @db.Text
  description String?          @db.Text
  required    Boolean          @default(true)
  options     Json?
  points      Int              @default(0)
  sortOrder   Int              @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  answers     FormAnswer[]

  @@index([testId, sortOrder])
}

model FormResponse {
  id             String       @id @default(cuid())
  testId         String
  test           FormTest     @relation(fields: [testId], references: [id], onDelete: Cascade)
  respondentId   String?
  respondent     User?        @relation("FormResponseRespondent", fields: [respondentId], references: [id], onDelete: SetNull)
  respondentName String
  submitterHash  String?
  score          Int?
  maxScore       Int          @default(0)
  reviewNote     String?      @db.Text
  reviewedAt     DateTime?
  reviewedById   String?
  reviewedBy     User?        @relation("FormResponseReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  submittedAt    DateTime     @default(now())

  answers        FormAnswer[]

  @@unique([testId, respondentId])
  @@index([testId, submitterHash])
  @@index([testId, submittedAt])
  @@index([respondentId, submittedAt])
  @@index([submitterHash])
  @@index([reviewedById])
}

model FormTestSession {
  id             String    @id @default(cuid())
  testId         String
  test           FormTest  @relation(fields: [testId], references: [id], onDelete: Cascade)
  userId         String
  user           User      @relation("FormTestSessionUser", fields: [userId], references: [id], onDelete: Cascade)
  startedAt      DateTime  @default(now())
  expiresAt      DateTime?
  completedAt    DateTime?
  lastSeenAt     DateTime  @default(now())
  securityEvents Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([userId, completedAt, expiresAt])
  @@index([testId, userId, startedAt])
}

model FormAnswer {
  id         String       @id @default(cuid())
  responseId String
  response   FormResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
  questionId String
  question   FormQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  value      Json
  createdAt  DateTime     @default(now())

  @@unique([responseId, questionId])
  @@index([questionId])
}

model JobApplication {
  id                     String               @id @default(cuid())
  applicantId            String               @unique
  applicant              User                 @relation("JobApplicationApplicant", fields: [applicantId], references: [id], onDelete: Cascade)
  discordId              String
  discordUsername        String?
  discordGlobalName      String?
  discordAvatar          String?
  applicantDisplayName   String
  status                 JobApplicationStatus @default(SUBMITTED)
  statusText             String               @default("Bewerbung wurde eingereicht") @db.VarChar(500)
  internalNote           String?              @db.Text
  submittedAt            DateTime             @default(now())
  reviewedAt             DateTime?
  reviewedById           String?
  reviewedBy             User?                @relation("JobApplicationReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  updatedAt              DateTime             @updatedAt

  answers                JobApplicationAnswer[]

  @@index([status, updatedAt])
  @@index([submittedAt])
  @@index([discordId])
  @@index([reviewedById])
}

model JobApplicationAnswer {
  id            String           @id @default(cuid())
  applicationId String
  application   JobApplication   @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  questionId    String
  questionTitle String           @db.Text
  questionType  FormQuestionType
  value         Json
  sortOrder     Int              @default(0)
  createdAt     DateTime         @default(now())

  @@unique([applicationId, questionId])
  @@index([applicationId, sortOrder])
}

model PressRelease {
  id          String             @id @default(cuid())
  title       String
  slug        String             @unique
  summary     String?            @db.Text
  content     String             @db.Text
  imageUrl    String?            @db.Text
  imageAlt    String?
  status      PressReleaseStatus @default(DRAFT)
  publishedAt DateTime?
  createdById String?
  createdBy   User?              @relation("PressReleaseCreator", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById String?
  updatedBy   User?              @relation("PressReleaseUpdater", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([status, publishedAt])
  @@index([createdAt])
  @@index([createdById])
  @@index([updatedById])
}

model Officer {
  id              String        @id @default(cuid())
  badgeNumber     String
  /// Discord-Snowflake (nur Dashboard / Verknüpfung; ohne Bot-Anbindung)
  discordId       String?       @unique
  firstName       String
  lastName        String
  rankId          String
  rank            Rank          @relation(fields: [rankId], references: [id])
  status          OfficerStatus @default(ACTIVE)
  unit            String?
  units           Json?
  flag            OfficerFlag?
  notes           String?
  hireDate        DateTime      @default(now())
  lastOnline      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  trainings       OfficerTraining[]
  promotionLogs   PromotionLog[]
  terminations    Termination[]
  sanctions        Sanction[]
  officerNotes    Note[]         @relation("OfficerNotes")
  auditLogs       AuditLog[]     @relation("AuditOfficer")
  rankChangeEntries RankChangeListEntry[]
  taskAssignments TaskAssignment[] @relation("TaskAssigned")
  dutySessions    DutyTimeSession[]
  playtimeSessions PlaytimeSession[]
  absenceNotices  AbsenceNotice[]
  probation        Probation?
  calendarEvents   CalendarEvent[] @relation("CalendarEventOfficer")
  patrolAssignments PatrolAssignment[] @relation("PatrolAssigned")
  patrolSessions  PatrolSession[]   @relation("PatrolSessionOfficer")
  dispatchCenters DispatchCenterState[] @relation("DispatchCenterOfficer")

  @@index([badgeNumber])
}

model CalendarEvent {
  id                  String            @id @default(cuid())
  module              TaskModule?
  title               String
  description         String?           @db.Text
  type                CalendarEventType @default(OTHER)
  startsAt            DateTime
  endsAt              DateTime?
  location            String?
  officerId           String?
  officer             Officer?          @relation("CalendarEventOfficer", fields: [officerId], references: [id], onDelete: SetNull)
  createdById         String?
  createdBy           User?             @relation("CalendarEventCreator", fields: [createdById], references: [id], onDelete: SetNull)
  discordAnnouncement Boolean           @default(false)
  discordChannelId    String?
  discordMessageId    String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@index([startsAt])
  @@index([module, startsAt])
  @@index([type, startsAt])
  @@index([officerId, startsAt])
}

model SruFolder {
  id          String   @id @default(cuid())
  module      TaskModule @default(SRU)
  name        String
  description String?  @db.Text
  color       String   @default("#d4af37")
  sortOrder   Int      @default(0)
  createdById String?
  createdBy   User?    @relation("SruFolderCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  documents   SruDocument[]

  @@index([module, sortOrder, createdAt])
}

model SruDocument {
  id          String    @id @default(cuid())
  module      TaskModule @default(SRU)
  folderId    String?
  folder      SruFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  title       String
  content     String    @db.Text
  sortOrder   Int       @default(0)
  createdById String?
  createdBy   User?     @relation("SruDocumentCreator", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById String?
  updatedBy   User?     @relation("SruDocumentUpdater", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([folderId, sortOrder])
  @@index([module, updatedAt])
  @@index([updatedAt])
}

model Probation {
  id          String          @id @default(cuid())
  officerId   String          @unique
  officer     Officer         @relation(fields: [officerId], references: [id], onDelete: Cascade)
  startsAt    DateTime        @default(now())
  endsAt      DateTime
  status      ProbationStatus @default(ACTIVE)
  checklist   Json?
  resultNote  String?         @db.Text
  decidedAt   DateTime?
  decidedById String?
  decidedBy   User?           @relation("ProbationDecider", fields: [decidedById], references: [id], onDelete: SetNull)
  createdById String?
  createdBy   User?           @relation("ProbationCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([status, endsAt])
}

model AbsenceNotice {
  id              String   @id @default(cuid())
  officerId       String
  officer         Officer  @relation(fields: [officerId], references: [id], onDelete: Cascade)
  startsAt        DateTime @default(now())
  endsAt          DateTime
  reason          String   @db.Text
  source          String   @default("discord")
  actorDiscordId  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([officerId, startsAt])
  @@index([endsAt])
}

model DutyTimeSession {
  id             String    @id @default(cuid())
  officerId      String
  officer        Officer   @relation(fields: [officerId], references: [id], onDelete: Cascade)
  clockInAt      DateTime  @default(now())
  clockOutAt     DateTime?
  clockInSource  String    @default("dashboard")
  clockOutSource String?
  actorDiscordId String?
  activityCheckSentAt    DateTime?
  activityCheckMessageId String?
  activityCheckChannelId String?
  activityConfirmedAt    DateTime?
  autoClockedOut         Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([officerId, clockInAt])
  @@index([clockOutAt])
}

model PlaytimeSession {
  id             String    @id @default(cuid())
  officerId      String?
  officer        Officer?  @relation(fields: [officerId], references: [id], onDelete: SetNull)
  discordId      String?
  license        String?
  playerName     String
  sourceServerId Int?
  startedAt      DateTime  @default(now())
  endedAt        DateTime?
  lastSeenAt     DateTime  @default(now())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([officerId, startedAt])
  @@index([discordId])
  @@index([license])
  @@index([endedAt])
}

model OfficerTraining {
  id         String   @id @default(cuid())
  officerId  String
  officer    Officer  @relation(fields: [officerId], references: [id], onDelete: Cascade)
  trainingId String
  training   Training @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  completed  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([officerId, trainingId])
}

model PromotionLog {
  id                String   @id @default(cuid())
  officerId         String
  officer           Officer  @relation(fields: [officerId], references: [id], onDelete: Cascade)
  oldRankId         String
  oldRank           Rank     @relation("OldRank", fields: [oldRankId], references: [id])
  newRankId         String
  newRank           Rank     @relation("NewRank", fields: [newRankId], references: [id])
  oldBadgeNumber    String?
  newBadgeNumber    String?
  performedByUserId String?
  performedBy       User?    @relation("PerformedBy", fields: [performedByUserId], references: [id], onDelete: SetNull)
  note              String?
  createdAt         DateTime @default(now())
}

model Termination {
  id                  String    @id @default(cuid())
  /// Bei Löschen des Officers: null bleibt; Anzeige über previous*-Felder.
  officerId           String?
  officer             Officer?  @relation(fields: [officerId], references: [id], onDelete: SetNull)
  reason              String
  terminatedByUserId  String?
  terminatedBy        User?     @relation("TerminatedBy", fields: [terminatedByUserId], references: [id], onDelete: SetNull)
  terminatedAt        DateTime  @default(now())
  previousRank        String?
  previousBadgeNumber String?
  previousFirstName   String?
  previousLastName    String?
}

model Sanction {
  id                  String         @id @default(cuid())
  officerId           String?
  officer             Officer?       @relation(fields: [officerId], references: [id], onDelete: SetNull)
  reason              String         @db.Text
  penalGrade          String
  fineAmount          Int?
  penalty             String?        @db.Text
  status              SanctionStatus @default(OPEN)
  dueAt               DateTime?
  paidAt              DateTime?
  resolvedAt          DateTime?
  escalatedAt         DateTime?
  parentSanctionId    String?
  parentSanction      Sanction?      @relation("SanctionEscalation", fields: [parentSanctionId], references: [id], onDelete: SetNull)
  escalatedSanctions  Sanction[]     @relation("SanctionEscalation")
  discordChannelId    String?
  discordMessageId    String?
  issuedByUserId      String?
  issuedBy            User?          @relation("SanctionIssuedBy", fields: [issuedByUserId], references: [id], onDelete: SetNull)
  previousRank        String?
  previousBadgeNumber String?
  previousFirstName   String?
  previousLastName    String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([officerId, createdAt])
  @@index([issuedByUserId, createdAt])
  @@index([status, dueAt])
  @@index([parentSanctionId])
}

model Note {
  id        String   @id @default(cuid())
  officerId String?
  officer   Officer? @relation("OfficerNotes", fields: [officerId], references: [id], onDelete: Cascade)
  authorId  String?
  author    User?    @relation("NoteAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  title     String?
  content   String
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String
  officerId   String?
  officer     Officer? @relation("AuditOfficer", fields: [officerId], references: [id], onDelete: SetNull)
  userId      String?
  user        User?    @relation("AuditUser", fields: [userId], references: [id], onDelete: SetNull)
  oldValue    String?  @db.Text
  newValue    String?  @db.Text
  details     String?  @db.Text
  createdAt   DateTime @default(now())
}

model RankChangeList {
  id          String   @id @default(cuid())
  name        String
  description String?
  type        String   @default("PROMOTION") // PROMOTION or DEMOTION
  status      String   @default("DRAFT")     // DRAFT, COMPLETED
  createdById String?
  createdBy   User?    @relation("ListCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  entries RankChangeListEntry[]
}

model RankChangeListEntry {
  id             String   @id @default(cuid())
  listId         String
  list           RankChangeList @relation(fields: [listId], references: [id], onDelete: Cascade)
  officerId      String
  officer        Officer  @relation(fields: [officerId], references: [id], onDelete: Cascade)
  currentRankId  String
  currentRank    Rank     @relation("EntryCurrentRank", fields: [currentRankId], references: [id])
  proposedRankId String
  proposedRank   Rank     @relation("EntryProposedRank", fields: [proposedRankId], references: [id])
  newBadgeNumber String?
  note           String?
  executed       Boolean  @default(false)
  executedAt     DateTime?
  createdById    String?
  createdBy      User?    @relation("EntryCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt      DateTime @default(now())

  @@unique([listId, officerId])
}

model SystemSetting {
  id    String @id @default(cuid())
  key   String @unique
  /// JSON payloads (Discord role maps, etc.) exceed MySQL DEFAULT VARCHAR limits.
  value String @db.Text
}

model TaskList {
  id          String     @id @default(cuid())
  module      TaskModule
  title       String
  description String?    @db.Text
  color       String     @default("#d4af37")
  archived    Boolean    @default(false)
  sortOrder   Int        @default(0)
  createdById String?
  createdBy   User?      @relation("TaskListCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  tasks       Task[]

  @@index([module, archived])
}

model Task {
  id          String       @id @default(cuid())
  listId      String
  list        TaskList     @relation(fields: [listId], references: [id], onDelete: Cascade)
  title       String
  description String?      @db.Text
  status      TaskStatus   @default(OPEN)
  priority    TaskPriority @default(NORMAL)
  dueDate     DateTime?
  completedAt DateTime?
  sortOrder   Int          @default(0)
  createdById String?
  createdBy   User?        @relation("TaskCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  assignments TaskAssignment[]

  @@index([listId, status])
}

model TaskAssignment {
  id         String   @id @default(cuid())
  taskId     String
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  officerId  String
  officer    Officer  @relation("TaskAssigned", fields: [officerId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())

  @@unique([taskId, officerId])
  @@index([officerId])
}

model PatrolBoard {
  id          String   @id @default(cuid())
  title       String
  startsAt    DateTime
  createdById String?
  createdBy   User?    @relation("PatrolBoardCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  patrols     PatrolUnit[]

  @@index([startsAt])
}

model PatrolUnit {
  id         String   @id @default(cuid())
  boardId    String
  board      PatrolBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)
  name       String
  callSign   String?
  assignment String?  @db.Text
  notes      String?  @db.Text
  status     Int?
  scope      String?
  assignedDispatchId Int?
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  members    PatrolAssignment[]

  @@index([boardId, sortOrder])
}

model PatrolAssignment {
  id         String   @id @default(cuid())
  patrolId   String
  patrol     PatrolUnit @relation(fields: [patrolId], references: [id], onDelete: Cascade)
  officerId  String
  officer    Officer @relation("PatrolAssigned", fields: [officerId], references: [id], onDelete: Cascade)
  sortOrder  Int      @default(0)
  assignedAt DateTime @default(now())

  @@unique([patrolId, officerId])
  @@index([officerId])
}

model PatrolSession {
  id                String    @id @default(cuid())
  /// FiveM-Session-ID → idempotentes Re-Senden (Upsert-Schlüssel). null = kein Dedupe.
  externalId        String?   @unique
  /// Per officerDiscordId aufgelöst; null = (noch) kein passender Officer.
  officerId         String?
  officer           Officer?  @relation("PatrolSessionOfficer", fields: [officerId], references: [id], onDelete: SetNull)
  officerDiscordId  String?
  officerName       String
  scope             String
  patrolName        String
  designationAtJoin String?
  gradeAtJoin       Int?
  joinedAt          DateTime
  leftAt            DateTime?
  durationSeconds   Int
  /// leave | disband | crew | disconnect | server_shutdown
  endReason         String
  createdAt         DateTime  @default(now())

  @@index([officerId])
  @@index([joinedAt])
  @@index([scope])
  @@index([officerDiscordId])
}

model DispatchCenterState {
  scope      String    @id
  officerId  String?
  officer    Officer?  @relation("DispatchCenterOfficer", fields: [officerId], references: [id], onDelete: SetNull)
  occupiedAt DateTime?
  updatedAt  DateTime  @updatedAt
}

model BadgeBlacklist {
  id          String   @id @default(cuid())
  badgeNumber String   @unique
  reason      String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ApiToken {
  id          String    @id @default(cuid())
  name        String
  /// Erste Zeichen des Tokens (z. B. "lspd_p4A8xKz…") — wird in Listen angezeigt,
  /// damit User Tokens unterscheiden können, ohne das Geheimnis preiszugeben.
  prefix      String
  /// SHA-256-Hash des Klartext-Tokens. Der Klartext wird NIE persistiert und nur
  /// einmalig beim Anlegen zurückgegeben — vergleichbar zu GitHub PATs.
  tokenHash   String    @unique
  /// Inhaber des Tokens (Subject — dessen Rechte gelten).
  userId      String
  user        User      @relation("ApiTokenOwner", fields: [userId], references: [id], onDelete: Cascade)
  /// Optional: Admin, der den Token erstellt hat. Leer = self-service.
  createdById String?
  createdBy   User?     @relation("ApiTokenCreator", fields: [createdById], references: [id], onDelete: SetNull)
  /// Whitelist von Permissions. Leer = alle Rechte des Inhabers.
  scopes      Json      @default("[]")
  /// Optional: nur innerhalb dieses Zeitraums gültig. null = unbegrenzt.
  expiresAt   DateTime?
  /// Letzter erfolgreicher Auth-Lookup. Wird throttled aktualisiert.
  lastUsedAt  DateTime?
  /// Anzahl erfolgreicher Auth-Lookups (für "letzte Aktivität"-Listen).
  usageCount  Int       @default(0)
  /// Soft-Revoke: Token bleibt in der DB sichtbar, ist aber nicht mehr gültig.
  revokedAt   DateTime?
  revokedReason String? @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  usages      ApiTokenUsage[]

  @@index([userId])
  @@index([tokenHash])
  @@index([revokedAt])
  @@index([createdById])
}

model ApiTokenUsage {
  id         String   @id @default(cuid())
  tokenId    String
  token      ApiToken @relation(fields: [tokenId], references: [id], onDelete: Cascade)
  /// HTTP-Methode (GET, POST, …)
  method     String
  /// Aufgerufener Pfad (z. B. "/api/officers")
  path       String
  /// Antwort-Statuscode
  statusCode Int
  /// Antwortdauer in Millisekunden
  durationMs Int
  /// Eingeschränkter User-Agent (erste 200 Zeichen)
  userAgent  String?  @db.VarChar(200)
  /// IP-Adresse (aus x-forwarded-for oder remote addr)
  ip         String?  @db.VarChar(64)
  createdAt  DateTime @default(now())

  @@index([tokenId, createdAt])
  @@index([createdAt])
}
